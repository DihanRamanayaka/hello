        <script>
          (function() {
            // Setup paths to local audio assets folder
            const localTracks = [
              'assets/music/Music1.mp3',
            ]

            let currentIdx = 0;
            let playingState = false;
            let islandExpanded = false;
            let stickyLock = false;
            let repeatEnabled = true;

            // Standard HTML5 Audio instance
            const audioPlayer = new Audio();

            // Grab Core Layout Nodes
            const island = document.getElementById('sc-dynamic-island');
            const compactArt = document.getElementById('sc-compact-art');
            const compactEq = document.getElementById('sc-compact-eq');
            const expArt = document.getElementById('sc-expanded-art');
            const expTitle = document.getElementById('sc-expanded-title');
            const expArtist = document.getElementById('sc-expanded-artist');
            const waveCanvas = document.getElementById('sc-wave-canvas');
            const canvasCtx = waveCanvas.getContext('2d');

            const timelineBar = document.getElementById('sc-timeline-bar');
            const timelineFill = document.getElementById('sc-timeline-fill');
            const timelineHandle = document.getElementById('sc-timeline-handle');
            const labelCurr = document.getElementById('sc-time-curr');
            const labelRem = document.getElementById('sc-time-rem');

            const btnPrev = document.getElementById('sc-btn-prev');
            const btnPlay = document.getElementById('sc-btn-play');
            const btnPlayIcon = document.getElementById('sc-play-icon');
            const btnNext = document.getElementById('sc-btn-next');
            const btnRepeat = document.getElementById('sc-btn-repeat');
            const btnLock = document.getElementById('sc-btn-lock');

            function initPlayerEvents() {
              // Audio Native Event listeners
              audioPlayer.addEventListener('play', () => {
                syncPlaybackUI(true);
              });

              audioPlayer.addEventListener('pause', () => {
                syncPlaybackUI(false);
              });

              audioPlayer.addEventListener('timeupdate', () => {
                if (!audioPlayer.duration) return;
                const currentPos = audioPlayer.currentTime * 1000;
                const relativePos = audioPlayer.currentTime / audioPlayer.duration;
                syncScrubberTimeline(currentPos, relativePos);
              });

              audioPlayer.addEventListener('ended', () => {
                if (repeatEnabled) {
                  audioPlayer.currentTime = 0;
                  audioPlayer.play().catch(err => {
                    console.warn("Browser blocked autoplay gesture:", err);
                  });
                } else {
                  transitionToTrack(currentIdx + 1);
                }
              });

              registerInteractionEvents();
              loadTrack(currentIdx, false); // Initialize the metadata for first track
            }

            // Reads binary tag chunks from local files (ID3v2, MP4, FLAC, etc.)
            function extractMetadata(filePath, callback) {
              if (typeof jsmediatags === 'undefined') {
                fallbackMetadata(filePath, callback);
                return;
              }

              // Convert relative track to absolute path with scheme to bypass jsmediatags constraints
              const absoluteUrl = window.location.origin + '/' + filePath;

              jsmediatags.read(absoluteUrl, {
                onSuccess: function(tag) {
                  const tags = tag.tags;
                  let title = tags.title || getFilenameWithoutExtension(filePath);
                  let artist = tags.artist || "Local Artist";
                  let artwork = null;

                  // Parse binary buffer artwork if embedded in mp3 file
                  if (tags.picture) {
                    const pic = tags.picture;
                    let base64String = "";
                    for (let i = 0; i < pic.data.length; i++) {
                      base64String += String.fromCharCode(pic.data[i]);
                    }
                    artwork = `data:${pic.format};base64,${window.btoa(base64String)}`;
                  }

                  callback({ title, artist, artwork });
                },
                onError: function(error) {
                  console.warn("jsmediatags extraction failed, applying filename fallback: ", error);
                  fallbackMetadata(filePath, callback);
                }
              });
            }

            // Elegant fallback if files are tagless or running direct on file:/// protocol
            function fallbackMetadata(filePath, callback) {
              const cleanName = getFilenameWithoutExtension(filePath);
              // Try to intelligently split string based on artist-song structures (e.g. "Chevy - Circles")
              const parts = cleanName.split(' - ');
              let artist = "Local Library";
              let title = cleanName;

              if (parts.length > 1) {
                artist = parts[0].replace(/-/g, ' ').toUpperCase();
                title = parts.slice(1).join(' - ');
              }

              callback({
                title: title,
                artist: artist,
                artwork: null
              });
            }

            function getFilenameWithoutExtension(path) {
              const parts = path.split('/');
              const file = parts[parts.length - 1];
              return decodeURIComponent(file.substring(0, file.lastIndexOf('.')) || file);
            }

            function loadTrack(idx, triggerPlay = true) {
              const trackPath = localTracks[idx];
              audioPlayer.src = trackPath;
              audioPlayer.load();

              // Clear layout elements while parsing
              expTitle.textContent = "Loading...";
              expArtist.textContent = "Parsing Tags...";
              compactArt.textContent = "♪";
              compactArt.style.backgroundImage = "";
              expArt.textContent = "♪";
              expArt.style.backgroundImage = "";

              // Display hardcoded metadata
              const title = '3:03 PM';
              const artist = 'しゃろう Sharou';
              const artworkPath = 'assets/music/art1.jpg';
              
              expTitle.textContent = title;
              expArtist.textContent = artist;
              
              compactArt.style.backgroundImage = `url('${artworkPath}')`;
              compactArt.textContent = '';
              expArt.style.backgroundImage = `url('${artworkPath}')`;
              expArt.textContent = '';

              if (triggerPlay) {
                audioPlayer.play().catch(err => {
                  console.warn("Browser blocked autoplay gesture:", err);
                });
              }
            }

            function registerInteractionEvents() {
              // Hover Actions (Desktop)
              island.addEventListener('mouseenter', () => {
                expandIslandState();
              });

              island.addEventListener('mouseleave', () => {
                if (!stickyLock) {
                  collapseIslandState();
                }
              });

              // Panel Sticky/Lock Feature
              btnLock.addEventListener('click', (e) => {
                e.stopPropagation();
                stickyLock = !stickyLock;
                btnLock.classList.toggle('locked', stickyLock);
                if (!stickyLock) {
                  collapseIslandState();
                }
              });

              // Media Player Controls binding
              btnPlay.addEventListener('click', (e) => {
                e.stopPropagation();
                toggleAudioPlayback();
              });

              btnPrev.addEventListener('click', (e) => {
                e.stopPropagation();
                transitionToTrack(currentIdx - 1);
              });

              btnNext.addEventListener('click', (e) => {
                e.stopPropagation();
                transitionToTrack(currentIdx + 1);
              });

              btnRepeat.addEventListener('click', (e) => {
                e.stopPropagation();
                repeatEnabled = !repeatEnabled;
                btnRepeat.classList.toggle('active', repeatEnabled);
              });

              // Manual seek timeline positioning
              timelineBar.addEventListener('click', (e) => {
                e.stopPropagation();
                if (!audioPlayer.duration) return;

                const bounds = timelineBar.getBoundingClientRect();
                const touchX = e.clientX - bounds.left;
                const progressPercent = Math.max(0, Math.min(1, touchX / bounds.width));

                audioPlayer.currentTime = audioPlayer.duration * progressPercent;
              });

              // Touch Interface Tap-to-Expand Switch (Mobile Devices)
              island.addEventListener('click', (e) => {
                const isInteractiveNode = e.target.closest('button') || e.target.closest('#sc-timeline-bar');
                if (!isInteractiveNode) {
                  if (islandExpanded) {
                    stickyLock = false;
                    btnLock.classList.remove('locked');
                    collapseIslandState();
                  } else {
                    stickyLock = true;
                    btnLock.classList.add('locked');
                    expandIslandState();
                  }
                }
              });
            }

            function syncPlaybackUI(isPlaying) {
              playingState = isPlaying;

              if (isPlaying) {
                btnPlayIcon.className = "fa-solid fa-pause";
                compactArt.classList.add('spinning');
                compactEq.classList.add('active');
                
                if (!islandExpanded) {
                  island.className = "sc-dynamic-island compact";
                }
              } else {
                btnPlayIcon.className = "fa-solid fa-play";
                btnPlayIcon.style.marginLeft = "2px";
                compactArt.classList.remove('spinning');
                compactEq.classList.remove('active');

                if (!islandExpanded) {
                  island.className = "sc-dynamic-island collapsed";
                }
              }
            }

            function toggleAudioPlayback() {
              if (audioPlayer.paused) {
                audioPlayer.play().catch(e => console.log(e));
              } else {
                audioPlayer.pause();
              }
            }

            function transitionToTrack(targetIdx) {
              if (targetIdx < 0) targetIdx = localTracks.length - 1;
              if (targetIdx >= localTracks.length) targetIdx = 0;

              currentIdx = targetIdx;
              loadTrack(currentIdx, true);
            }

            // Micro helpers to format timing parameters
            function processMsToLabel(ms) {
              if (isNaN(ms) || ms < 0) return "0:00";
              const totalSecs = Math.floor(ms / 1000);
              const minutes = Math.floor(totalSecs / 60);
              const seconds = totalSecs % 60;
              return `${minutes}:${seconds < 10 ? '0' : ''}${seconds}`;
            }

            function syncScrubberTimeline(currPosition, relPosition) {
              const percentValue = (relPosition * 100).toFixed(2);
              timelineFill.style.width = `${percentValue}%`;
              timelineHandle.style.left = `${percentValue}%`;

              labelCurr.textContent = processMsToLabel(currPosition);

              if (audioPlayer.duration) {
                const trackDur = audioPlayer.duration * 1000;
                const remMs = trackDur - currPosition;
                labelRem.textContent = `-${processMsToLabel(remMs)}`;
              } else {
                labelRem.textContent = "-0:00";
              }
            }

            // Dynamic Island Switch states
            function expandIslandState() {
              islandExpanded = true;
              island.className = "sc-dynamic-island expanded";
            }

            function collapseIslandState() {
              islandExpanded = false;
              if (playingState) {
                island.className = "sc-dynamic-island compact";
              } else {
                island.className = "sc-dynamic-island collapsed";
              }
            }

            function drawRealTimeAudioWaves() {
              if (!canvasCtx) return;
              canvasCtx.clearRect(0, 0, waveCanvas.width, waveCanvas.height);

              const columnBars = 14;
              const barWidth = 4;
              const barGap = 3;
              const horizontalOffset = (waveCanvas.width - (columnBars * (barWidth + barGap))) / 2;

              canvasCtx.fillStyle = '#00ffcc';

              for (let i = 0; i < columnBars; i++) {
                let blockHeight = 4;
                if (playingState) {
                  const runRate = Date.now() * 0.006;
                  blockHeight = Math.abs(Math.sin(runRate + i * 0.4) * Math.cos(runRate * 0.3 + i * 0.15)) * (waveCanvas.height - 6) + 4;
                } else {
                  blockHeight = 4 + Math.sin(Date.now() * 0.0015 + i * 0.8) * 1.5;
                }

                const positionX = horizontalOffset + i * (barWidth + barGap);
                const positionY = (waveCanvas.height - blockHeight) / 2;

                canvasCtx.beginPath();
                canvasCtx.roundRect(positionX, positionY, barWidth, blockHeight, 1.5);
                canvasCtx.fill();
              }

              requestAnimationFrame(drawRealTimeAudioWaves);
            }

            // Initialize the widget fully on window load
            window.addEventListener('load', () => {
              initPlayerEvents();
              drawRealTimeAudioWaves();
              // Activate repeat button visually
              btnRepeat.classList.add('active');
            });

          })();
        </script>
